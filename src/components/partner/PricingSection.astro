---
import SectionBadge from '../shared/SectionBadge.astro';

interface Props {
  badge: string;
  headline: string;
  plans: Array<{
    name: string;
    price: string;
    period: string;
    originalPrice: string;
    ctaText: string;
    ctaLink: string;
    features: string[];
  }>;
}

const { badge, headline, plans } = Astro.props;
---

<section class="pricing-section section-with-lines" id="pricing">
  <div class="pricing-outer">
    <div class="pricing-inner">
      <div class="pricing-header">
        <SectionBadge text={badge} />
        <h2 class="pricing-title">{headline}</h2>
      </div>

      <div class="pricing-cards">
        {plans.map((plan, index) => {
          const isPopular = index === 1;
          return (
            <div class:list={['pricing-card-outer', { 'card-popular': isPopular }]}>
              {isPopular && (
                <div class="popular-badge">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M7 1L8.854 4.854L13 5.584L10 8.5L10.708 12.628L7 10.7L3.292 12.628L4 8.5L1 5.584L5.146 4.854L7 1Z" fill="white"/>
                  </svg>
                  <span>Most Popular</span>
                </div>
              )}
              <div class:list={['pricing-card-inner', { 'card-inner-popular': isPopular }]}>
                <div class:list={['pricing-decoration', index === 0 ? 'deco-monthly' : 'deco-annual']}>
                  <img
                    src={index === 0 ? '/assets/figma/pricing-deco-monthly.svg' : '/assets/figma/pricing-deco-annual.svg'}
                    alt=""
                    class="deco-svg"
                  />
                </div>

                <div class="pricing-card-top">
                  <div class="pricing-plan-info">
                    <img
                      src={index === 0 ? '/assets/figma/pricing-icon-monthly.svg' : '/assets/figma/pricing-icon-annual.svg'}
                      alt=""
                      class:list={['pricing-icon', index === 0 ? 'icon-monthly' : 'icon-annual']}
                    />
                    <div class="plan-name-price">
                      <p class="plan-name">{plan.name}</p>
                      <div class="price-row">
                        <span class="plan-price">{plan.price}</span>
                        <span class="plan-original-price">{plan.originalPrice}</span>
                        {isPopular && <span class="plan-period">/{plan.period === '/year' ? 'yr' : 'mo'}</span>}
                      </div>
                    </div>
                  </div>

                  {isPopular && (
                    <div class="savings-callout">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="savings-icon">
                        <path d="M7 1L8.854 4.854L13 5.584L10 8.5L10.708 12.628L7 10.7L3.292 12.628L4 8.5L1 5.584L5.146 4.854L7 1Z" fill="#3DAEAE"/>
                      </svg>
                      <span>Save 10%</span>
                    </div>
                  )}

                  <div class="pricing-divider"></div>

                  <div class="plan-features">
                    {plan.features.map((feature) => (
                      <div class="plan-feature">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="check-svg" aria-hidden="true">
                          <circle cx="10" cy="10" r="10" fill={isPopular ? '#44C0C0' : '#E8E8E8'}/>
                          <path d="M6 10.5L8.5 13L14 7.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>{feature}</span>
                      </div>
                    ))}
                  </div>

                  <div class="pricing-cta-area">
                    <div class="pricing-divider"></div>
                    <a href={plan.ctaLink} class:list={['pricing-cta', { 'cta-popular': isPopular }]}>
                      {plan.ctaText}
                    </a>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    background: white;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 0;
  }

  .pricing-outer {
    max-width: var(--content-width);
    margin: 0 auto;
    width: 100%;
    padding: 0 20px;
  }

  .pricing-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pricing-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    margin-bottom: 60px;
    width: 760px;
  }

  .pricing-title {
    font-family: var(--font-primary);
    font-size: 60px;
    font-weight: 500;
    line-height: 60px;
    letter-spacing: -3.6px;
    text-transform: capitalize;
    color: var(--color-text-primary);
    margin: 0;
    text-align: center;
  }

  .pricing-cards {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 16px;
    width: 100%;
    max-width: 800px;
  }

  /* Base card */
  .pricing-card-outer {
    width: 376px;
    backdrop-filter: blur(6px);
    background: rgba(255, 255, 255, 0.4);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 20px;
    overflow: visible;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 8px;
    position: relative;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Popular card emphasis */
  .pricing-card-outer.card-popular {
    border: 2px solid #44C0C0;
    background: linear-gradient(180deg, rgba(68, 192, 192, 0.06) 0%, rgba(255, 255, 255, 0.5) 100%);
    box-shadow:
      0 4px 24px rgba(68, 192, 192, 0.12),
      0 1px 4px rgba(0, 0, 0, 0.04);
    transform: scale(1.03);
    z-index: 1;
  }

  .pricing-card-outer.card-popular:hover {
    transform: scale(1.04);
    box-shadow:
      0 8px 32px rgba(68, 192, 192, 0.18),
      0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .pricing-card-outer:not(.card-popular):hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  /* Popular badge */
  .popular-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 16px 4px 12px;
    background: #44C0C0;
    border-radius: 100px;
    white-space: nowrap;
    z-index: 2;
  }

  .popular-badge span {
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: -0.13px;
    color: white;
  }

  .pricing-card-inner {
    position: relative;
    width: 100%;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }

  .card-inner-popular {
    border-color: rgba(68, 192, 192, 0.15);
  }

  .pricing-decoration {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .deco-monthly {
    bottom: -1px;
    right: -1px;
    width: 249px;
    height: 150px;
  }

  .deco-annual {
    top: -1px;
    right: -1px;
    width: 275px;
    height: 181px;
  }

  .deco-svg {
    width: 100%;
    height: 100%;
  }

  .pricing-card-top {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
    z-index: 1;
  }

  .pricing-plan-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pricing-icon {
    overflow: hidden;
  }

  .icon-monthly {
    width: 60px;
    height: 60px;
  }

  .icon-annual {
    width: 52px;
    height: 52px;
  }

  .plan-name-price {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .plan-name {
    font-family: var(--font-primary);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.4px;
    color: var(--color-text-primary);
    margin: 0;
  }

  .price-row {
    display: flex;
    align-items: flex-end;
    gap: 4px;
  }

  .plan-price {
    font-family: var(--font-primary);
    font-size: 40px;
    font-weight: 500;
    letter-spacing: -1.6px;
    color: var(--color-text-primary);
  }

  .plan-original-price {
    font-family: var(--font-primary);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.88px;
    color: var(--color-text-primary);
    opacity: 0.4;
    text-decoration: line-through;
    padding-bottom: 4px;
  }

  .plan-period {
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 400;
    color: rgba(26, 26, 26, 0.5);
    padding-bottom: 6px;
  }

  .savings-callout {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 5px;
    padding: 5px 14px 5px 10px;
    background: rgba(68, 192, 192, 0.08);
    border: 1px solid rgba(68, 192, 192, 0.2);
    border-radius: 100px;
  }

  .savings-icon {
    flex-shrink: 0;
  }

  .savings-callout span {
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: -0.13px;
    color: #3DAEAE;
  }

  .pricing-divider {
    width: 100%;
    height: 1px;
    background: rgba(26, 26, 26, 0.08);
  }

  .plan-features {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .plan-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-primary);
    font-size: 15px;
    font-weight: 400;
    letter-spacing: -0.3px;
    color: var(--color-text-primary);
  }

  .check-svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .pricing-cta-area {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-top: 4px;
  }

  .pricing-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 44px;
    padding: 10px 20px;
    background: #44C0C0;
    color: white;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.32px;
    border-radius: 100px;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }

  .pricing-cta:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .pricing-cta:active {
    transform: translateY(0);
  }

  .pricing-cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .cta-popular {
    background: #44C0C0;
    box-shadow: 0 2px 12px rgba(68, 192, 192, 0.3);
    font-weight: 600;
  }

  .cta-popular:hover {
    box-shadow: 0 4px 20px rgba(68, 192, 192, 0.4);
  }

  @media (max-width: 1024px) {
    .pricing-section {
      padding: 80px 0;
    }

    .pricing-header {
      width: 100%;
      max-width: 760px;
    }

    .pricing-title {
      font-size: 44px;
      line-height: 48px;
      letter-spacing: -2.64px;
    }
  }

  @media (max-width: 768px) {
    .pricing-cards {
      flex-direction: column;
      align-items: center;
    }

    .pricing-card-outer {
      width: 100%;
      max-width: 376px;
    }

    .pricing-card-outer.card-popular {
      transform: none;
      order: -1;
    }

    .pricing-card-outer.card-popular:hover {
      transform: translateY(-2px);
    }
  }
</style>
