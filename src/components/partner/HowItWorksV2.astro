---
interface Props {
  badge: string;
  title: string;
  steps: Array<{
    text: string;
    active: boolean;
    bgImage: string;
    screenshot?: string;
  }>;
}

const { badge, title, steps } = Astro.props;

// Real screenshots mapped to each step (from logos-images folder)
const stepImages = [
  '/logos-images/howitworks1.png',
  '/logos-images/Group 2085662633.png',
  '/logos-images/Group 2085662653.png',
];
---

<section class="hiw-v2" aria-label="How Avery Works — Variant">
  <div class="hiw-v2-container">

    <!-- Header -->
    <div class="hiw-v2-header">
      <p class="hiw-v2-badge">• {badge}</p>
      <h2 class="hiw-v2-title">{title}</h2>
    </div>

    <!-- 3-card grid -->
    <div class="hiw-v2-grid">
      {steps.map((step, i) => (
        <div class="hiw-v2-card">
          <!-- Image area -->
          <div class="hiw-v2-media">
            <span class="hiw-v2-num">0{i + 1}</span>
            <img
              src={stepImages[i] || step.bgImage}
              alt={step.text}
              class="hiw-v2-img"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
          <!-- Text area -->
          <div class="hiw-v2-info">
            <p class="hiw-v2-step-label">Step {i + 1}</p>
            <p class="hiw-v2-step-text">{step.text}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Variant label -->
    <p class="hiw-v2-variant-tag">↑ Layout Variant B</p>

  </div>
</section>

<style>
  .hiw-v2 {
    padding: 80px 0 100px;
    background: var(--color-surface-muted, #F6F6F6);
  }

  .hiw-v2-container {
    max-width: var(--content-width, 1280px);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Header ── */
  .hiw-v2-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
    margin-bottom: 56px;
  }

  .hiw-v2-badge {
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: -0.64px;
    color: var(--color-primary, #44C0C0);
    margin: 0;
  }

  .hiw-v2-title {
    font-family: var(--font-primary);
    font-size: 52px;
    font-weight: 500;
    letter-spacing: -3.12px;
    line-height: 1.05;
    color: var(--color-text-primary, #1A1A1A);
    text-transform: capitalize;
    max-width: 580px;
    margin: 0;
  }

  /* ── Grid ── */
  .hiw-v2-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* ── Card ── */
  .hiw-v2-card {
    background: var(--color-surface, #fff);
    border-radius: 32px;
    border: 1px solid var(--color-border, rgba(26,26,26,0.1));
    box-shadow: 0px 4px 24px rgba(0,0,0,0.06), 0px 1px 4px rgba(0,0,0,0.03);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.2s ease;
  }

  .hiw-v2-card:hover {
    transform: translateY(-4px);
    box-shadow: 0px 12px 40px rgba(0,0,0,0.1), 0px 2px 8px rgba(0,0,0,0.04);
  }

  /* ── Media ── */
  .hiw-v2-media {
    position: relative;
    height: 260px;
    background: linear-gradient(145deg, #d4f4f4 0%, #e8fafa 60%, #c8efef 100%);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  /* Large watermark step number */
  .hiw-v2-num {
    position: absolute;
    top: -12px;
    right: 12px;
    font-family: var(--font-primary);
    font-size: 96px;
    font-weight: 700;
    letter-spacing: -4px;
    line-height: 1;
    color: #44C0C0;
    opacity: 0.12;
    user-select: none;
    pointer-events: none;
  }

  .hiw-v2-img {
    position: relative;
    z-index: 1;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 10px;
    box-shadow:
      0 8px 32px rgba(0,0,0,0.1),
      0 2px 8px rgba(0,0,0,0.05);
  }

  /* ── Info ── */
  .hiw-v2-info {
    padding: 24px 28px 28px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .hiw-v2-step-label {
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--color-primary, #44C0C0);
    margin: 0;
  }

  .hiw-v2-step-text {
    font-family: var(--font-primary);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.6px;
    line-height: 1.3;
    color: var(--color-text-primary, #1A1A1A);
    margin: 0;
  }

  /* ── Variant label ── */
  .hiw-v2-variant-tag {
    text-align: center;
    margin-top: 32px;
    font-family: var(--font-primary);
    font-size: 13px;
    color: var(--color-text-muted, rgba(26,26,26,0.5));
    letter-spacing: 0.2px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hiw-v2-grid {
      grid-template-columns: 1fr;
      gap: 16px;
      max-width: 560px;
      margin: 0 auto;
    }

    .hiw-v2-title {
      font-size: 36px;
      letter-spacing: -1.5px;
    }
  }

  @media (max-width: 768px) {
    .hiw-v2 {
      padding: 60px 0 80px;
    }

    .hiw-v2-title {
      font-size: 28px;
      letter-spacing: -0.8px;
    }

    .hiw-v2-media {
      height: 200px;
    }

    .hiw-v2-num {
      font-size: 72px;
    }
  }
</style>
