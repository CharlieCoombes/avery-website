---
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-divider"></div>
    <div class="footer-content">
      <div class="footer-copy-wrap">
        <p class="footer-copy">Copyright &copy; 2026 Avery. All rights reserved.</p>
      </div>
      <div class="footer-right">
        <img src="/assets/figma/footer-social-icons.svg" alt="Social media links" class="footer-social-svg" width="153" height="28" />
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    width: 100%;
    height: 177px;
    background: white;
    overflow: hidden;
    position: relative;
  }

  .footer-inner {
    position: absolute;
    top: 59.5px;
    left: 50%;
    transform: translateX(-50%);
    width: 1280px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .footer-divider {
    width: 100%;
    height: 1px;
    background: rgba(26, 26, 26, 0.1);
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copy-wrap {
    opacity: 0.7;
    padding: 12px 0;
  }

  .footer-copy {
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1;
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-social-svg {
    height: 28px;
    width: auto;
    opacity: 0.7;
  }

  @media (max-width: 1320px) {
    .footer-inner {
      width: 100%;
      padding: 0 20px;
    }
  }

  @media (max-width: 768px) {
    .footer {
      height: auto;
      padding: 40px 20px;
    }

    .footer-inner {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
    }

    .footer-content {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
</style>
